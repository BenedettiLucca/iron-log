{
  "expo": {
    "name": "Iron Log",
    "slug": "iron-log",
    "version": "3.12.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ironlog",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#E07A5F"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.lucca.ironlog",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#E07A5F"
      },
      "versionCode": 7
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#E07A5F",
          "dark": {
            "backgroundColor": "#1D1917"
          }
        }
      ],
      "expo-font",
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    }
  }
}
